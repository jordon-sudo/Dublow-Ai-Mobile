{
  "expo": {
    "name": "Dublow-AI-Mobile",
    "slug": "hatz-chat",
    "version": "0.37.0",
    "scheme": "haztchat",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "backgroundColor": "#000000",
    "splash": {
      "backgroundColor": "#000000",
      "resizeMode": "contain"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.dublowdigital.hatzchat",
      "backgroundColor": "#000000"
    },
    "android": {
      "package": "com.dublowdigital.hatzchat",
      "backgroundColor": "#000000"
    },
     "plugins": [
      ["expo-media-library", {
  "photosPermission": "Allow Hatz Chat to save generated images to your photo library.",
  "savePhotosPermission": "Allow Hatz Chat to save generated images to your photo library.",
  "isAccessMediaLocationEnabled": true
}],
      "expo-router",
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Hatz Chat to attach photos to your messages.",
          "cameraPermission": "Allow Hatz Chat to take photos for your messages."
        }
      ]
    ],
    "experiments": { "typedRoutes": true }
  
  }
}